<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1783418081600-1" author="user">
        <createTable tableName="providers">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_providers"/>
            </column>
            <column name="code" type="VARCHAR(255)"/>
            <column name="name" type="VARCHAR(255)"/>
            <column name="active" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1783418081600-2" author="user">
        <createTable tableName="transactions">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_transactions"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="provider_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="service_account" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(19, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="failure_reason" type="VARCHAR(255)"/>
            <column name="failure_timestamp" type="DATETIME"/>
            <column name="idempotency_key" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME"/>
        </createTable>
    </changeSet>
    <changeSet id="1783418081600-3" author="user">
        <createTable tableName="users">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_users"/>
            </column>
            <column name="full_name" type="VARCHAR(255)"/>
            <column name="phone" type="VARCHAR(255)"/>
            <column name="balance" type="DECIMAL(19, 2)"/>
            <column name="currency" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="BIGINT"/>
            <column name="created_at" type="DATETIME"/>
            <column name="updated_at" type="DATETIME"/>
        </createTable>
    </changeSet>
    <changeSet id="1783418081600-4" author="user">
        <addUniqueConstraint columnNames="code" constraintName="uc_providers_code" tableName="providers"/>
    </changeSet>
    <changeSet id="1783418081600-5" author="user">
        <addUniqueConstraint columnNames="idempotency_key" constraintName="uc_transactions_idempotencykey"
                             tableName="transactions"/>
    </changeSet>
    <changeSet id="1783418081600-6" author="user">
        <addUniqueConstraint columnNames="phone" constraintName="uc_users_phone" tableName="users"/>
    </changeSet>
    <changeSet id="1783418081600-7" author="user">
        <addForeignKeyConstraint baseColumnNames="provider_id" baseTableName="transactions"
                                 constraintName="FK_TRANSACTIONS_ON_PROVIDER" referencedColumnNames="id"
                                 referencedTableName="providers"/>
    </changeSet>
    <changeSet id="1783418081600-8" author="user">
        <addForeignKeyConstraint baseColumnNames="user_id" baseTableName="transactions"
                                 constraintName="FK_TRANSACTIONS_ON_USER" referencedColumnNames="id"
                                 referencedTableName="users"/>
    </changeSet>

</databaseChangeLog>